PORT=5000

# MongoDB Connection String
# For local: mongodb://localhost:27017/hotel_sachida
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/hotel_sachida
MONGODB_URI=mongodb://localhost:27017/hotel_sachida

# Razorpay API Keys (Get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXX

# Gmail App Password (IMPORTANT: Must be App Password, NOT your login password)
# 1. Enable 2FA on your Google account: https://myaccount.google.com/security
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password (with spaces) and use below
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Twilio Credentials (Get from https://console.twilio.com)
# SID and Auth Token from dashboard
TWILIO_SID=ACXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXX

# Twilio WhatsApp - IMPORTANT for Sandbox Testing:
# 1. Go to https://console.twilio.com → Explore Products → WhatsApp
# 2. Get your Sandbox "From" number (looks like whatsapp:+14155238886)
# 3. From your phone, send WhatsApp to that number with: "join your-keyword"
# 4. You'll be added to the sandbox
# 5. Use the Sandbox "From" number below
# For production: Register your business number with Twilio (takes 1-2 days for approval)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Hotel Owner Details
OWNER_EMAIL=owner@hotelname.com
OWNER_PHONE=+91XXXXXXXXXX
OWNER_WHATSAPP=XXXXXXXXXX  # Without +91, just the 10-digit number

# JWT Secret Key (Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Admin Credentials
ADMIN_EMAIL=admin@sachidapalace.com
ADMIN_PASSWORD=ComplexPassword123!@#

# Environment
NODE_ENV=development
