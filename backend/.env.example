PORT=5000

# MongoDB Connection String
# For local: mongodb://localhost:27017/hotel_sachida
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/hotel_sachida
MONGODB_URI=mongodb://localhost:27017/hotel_sachida

# Razorpay API Keys (Get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXX

# Gmail App Password (Generate from https://myaccount.google.com/apppasswords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Twilio Credentials (Get from https://console.twilio.com)
TWILIO_SID=ACXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+91XXXXXXXXXX

# Hotel Owner Details
OWNER_EMAIL=owner@hotelname.com
OWNER_PHONE=+91XXXXXXXXXX
OWNER_WHATSAPP=+91XXXXXXXXXX

# JWT Secret Key (Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Admin Credentials
ADMIN_EMAIL=admin@sachidapalace.com
ADMIN_PASSWORD=ComplexPassword123!@#

# Environment
NODE_ENV=development
